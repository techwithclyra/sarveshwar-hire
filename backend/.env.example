# Optional server-wide fallback key — students can instead paste their own
# OpenRouter key in the app banner, which is used per-request and takes
# priority over this one. Leave blank to require every student to bring
# their own key. Create a key at https://openrouter.ai/keys.
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
PORT=3001
ALLOWED_ORIGIN=http://localhost:5173

# Same Supabase project as the frontend (see frontend/.env.example) — the
# backend reads the problem bank from here for /api/problems and /api/evaluate.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_publishable_...

# Service role key (Supabase Dashboard -> Project Settings -> API -> service_role
# secret). Only used server-side to read/write the `students` table, which has
# no anon-key RLS policy at all. NEVER put this in frontend/.env or a VITE_ var.
SUPABASE_SERVICE_ROLE_KEY=

# Must match ADMIN_PASSWORD in frontend/src/config/constants.js — sent by the
# Admin Panel as a header to authorize the /api/admin/students endpoints.
ADMIN_PASSWORD=
