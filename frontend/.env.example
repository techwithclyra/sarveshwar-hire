VITE_API_BASE=http://localhost:3001
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=sb_publishable_...

# "Continue with Google" uses Supabase Auth's Google provider — no extra
# frontend var is needed, but you must enable it once in the dashboard:
#   Supabase Dashboard -> Authentication -> Providers -> Google -> enable,
#   paste a Google OAuth Client ID + Secret (from Google Cloud Console),
#   then add your app origin (e.g. http://localhost:5173) under
#   Authentication -> URL Configuration -> Redirect URLs.
# The backend also needs SUPABASE_SERVICE_ROLE_KEY set (see backend/.env.example)
# so it can verify the Google session and create the student record.
